#!/bin/sh
# mirrorsh - tiny POSIX sh mirror switcher for Linux and embedded devices
# https://github.com/<owner>/mirrorsh
#
# 一个轻量、无依赖、适合 Linux 小设备的软件源切换脚本。
# 第一版支持: Debian / Ubuntu / Alpine / OpenWrt
#
# POSIX sh only. No bash-isms. No python/perl/jq/awk hard dependency.
# Designed to survive on BusyBox / 随身 WiFi / 软路由 / 嵌入式 Linux.
#
# License: MIT

VERSION="v0.1.0"

# ---------------------------------------------------------------------------
# Path overrides (production defaults to /etc; tests inject ROOT_DIR/ETC_DIR)
# ---------------------------------------------------------------------------
ROOT_DIR="${ROOT_DIR:-}"
ETC_DIR="${ETC_DIR:-${ROOT_DIR}/etc}"

OS_RELEASE="$ETC_DIR/os-release"
DEBIAN_VERSION="$ETC_DIR/debian_version"
ALPINE_RELEASE="$ETC_DIR/alpine-release"
OPENWRT_RELEASE="$ETC_DIR/openwrt_release"

APT_DIR="$ETC_DIR/apt"
APT_LIST="$APT_DIR/sources.list"
APT_SOURCES_D="$APT_DIR/sources.list.d"
APK_REPOS="$ETC_DIR/apk/repositories"
OPKG_FEEDS="$ETC_DIR/opkg/distfeeds.conf"

CA_FILES="$ETC_DIR/ssl/certs/ca-certificates.crt $ETC_DIR/ssl/cert.pem $ETC_DIR/pki/tls/certs/ca-bundle.crt"

BACKUP_ROOT="${MIRRORSH_BACKUP_DIR:-$ETC_DIR/mirrorsh/backup}"

# ---------------------------------------------------------------------------
# Runtime options (set by argument parser)
# ---------------------------------------------------------------------------
CMD=""              # menu|switch|help|version|list|check|restore
MIRROR=""
PROTOCOL="auto"     # auto|http|https
DRY_RUN=0
YES=0
DO_UPDATE=1
DEBUG=0
NO_COLOR=0
SCHEME=""           # resolved http|https

# detected system facts
DISTRO=""
DISTRO_VERSION=""
CODENAME=""
ARCH=""
PKG_MGR=""

# per-switch plan (filled by plan_* functions)
TARGET_FILE=""
NEW_CONTENT=""
DISABLE_FILES=""
OW_ORIG=""
OW_ORIG_SET=0

# backup state
BACKUP_DIR=""
TS=""

# temp file currently being written (for interrupt cleanup)
MIRRORSH_TMP=""

# ---------------------------------------------------------------------------
# Output helpers (color is optional, never required)
# ---------------------------------------------------------------------------
setup_colors() {
	if [ "$NO_COLOR" = 1 ] || [ ! -t 1 ]; then
		C_RED='' C_GRN='' C_YEL='' C_BLU='' C_DIM='' C_RST=''
	else
		C_RED='\033[31m' C_GRN='\033[32m' C_YEL='\033[33m'
		C_BLU='\033[34m' C_DIM='\033[2m' C_RST='\033[0m'
	fi
}

say()   { printf '%s\n' "$*"; }
info()  { printf '%b%s%b\n' "$C_BLU" "$*" "$C_RST"; }
ok()    { printf '%b%s%b\n' "$C_GRN" "$*" "$C_RST"; }
warn()  { printf '%b%s%b\n' "$C_YEL" "$*" "$C_RST" >&2; }
err()   { printf '%b%s%b\n' "$C_RED" "$*" "$C_RST" >&2; }
debug() { [ "$DEBUG" = 1 ] && printf '%b[debug] %s%b\n' "$C_DIM" "$*" "$C_RST" >&2; return 0; }
die()   { err "错误: $*"; exit 1; }

have() { command -v "$1" >/dev/null 2>&1; }

# directory of a path without the dirname binary
dir_of() { case "$1" in */*) printf '%s' "${1%/*}";; *) printf '%s' ".";; esac; }

# ---------------------------------------------------------------------------
# Help / version
# ---------------------------------------------------------------------------
show_version() { say "mirrorsh $VERSION"; }

show_help() {
	cat <<EOF
mirrorsh $VERSION - tiny POSIX sh mirror switcher
轻量、无依赖、适合 Linux 小设备的软件源切换脚本

用法:
  sh mirrorsh                      进入交互式菜单 (需要 /dev/tty)
  sh mirrorsh [选项]

选项:
  --help                显示本帮助
  --version             显示版本号
  --list                列出支持的镜像与当前系统可用镜像
  --check               只检测系统信息, 不修改任何文件
  --mirror <name>       指定镜像, 如 ustc / aliyun / official
  --protocol <p>        协议 auto|http|https (默认 auto)
  --dry-run             只打印将写入内容, 不修改系统
  --yes                 跳过确认
  --no-update           切换后不执行 apt/apk/opkg update
  --restore             恢复最近一次 mirrorsh 备份
  --debug               输出更多诊断信息
  --no-color            禁用彩色输出

典型用法:
  sh mirrorsh --check
  sh mirrorsh --list
  sh mirrorsh --mirror ustc --dry-run
  sh mirrorsh --mirror aliyun --yes
  sh mirrorsh --mirror official --yes
  sh mirrorsh --mirror ustc --protocol http --yes
  sh mirrorsh --restore

第一版支持: Debian / Ubuntu / Alpine / OpenWrt
mirrorsh 只切换软件源并执行 update, 不会执行 upgrade/full-upgrade。
